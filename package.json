{
  "dependencies": {
    "better-sqlite3": "^8.4.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "node-ical": "^0.26.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.11",
    "vitest": "^1.0.0"
  },
  "scripts": {
    "dev:server": "tsx watch server.ts",
    "dev:client": "vite",
    "dev": "concurrently -n server,client -c blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:client": "vite build",
    "test": "vitest run",
    "start:all": "npm run build:client && concurrently -n server,client -c blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "show:db": "sqlitebrowser data/app.db"
  }
}
